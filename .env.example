# AI (kamida bittasi majburiy)
OPENAI_API_KEY=
# Mahalliy LLM (Ollama va hokazo): base URL va model
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Yoki Claude
ANTHROPIC_API_KEY=
AI_PROVIDER=openai

# Telegram (ixtiyoriy — `docker compose --profile telegram up -d`)
TELEGRAM_BOT_TOKEN=

# SSH: konteyner ichida kalit fayl yo‘li (server.key_path) yoki base64
SSH_KEYS_DIR=./ssh-keys
SSH_PRIVATE_KEY_B64=
# Worker: SSH qayta urinish (ixtiyoriy)
SSH_CONNECT_RETRIES=3
SSH_RETRY_BACKOFF_SECONDS=2

# Telegram bot (aiogram): HTTP qayta urinish va polling
HTTP_RETRIES=3
POLL_INTERVAL_SEC=2
POLL_MAX_ROUNDS=120
