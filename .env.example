# === DATABASE ===
POSTGRES_DB=devops_agent
POSTGRES_USER=devops
POSTGRES_PASSWORD=change_me_strong_password_here
# Sync URL for SQLAlchemy + Alembic (psycopg2). +asyncpg qismi avtomatik olib tashlanadi.
DATABASE_URL=postgresql://devops:change_me_strong_password_here@postgres:5432/devops_agent

# === REDIS ===
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0
CELERY_BROKER_URL=redis://:change_me_redis_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change_me_redis_password@redis:6379/0

# === SECURITY ===
# openssl rand -hex 32
MASTER_ENCRYPTION_KEY=
# yoki (oldingi format): openssl rand -base64 32
ENCRYPTION_MASTER_KEY_B64=

# openssl rand -hex 64
JWT_SECRET=generate_with_openssl_rand_hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# openssl rand -hex 32 — bot va ichki chaqiruvlar
API_INTERNAL_SECRET=generate_with_openssl_rand_hex_32

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=your_bot_username_without_at

# === APP ===
APP_ENV=production
APP_URL=https://your-domain.com
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8080,http://127.0.0.1:8080,http://web,http://localhost:5173
WEB_PORT=8080
API_PORT=8000

# === ADMIN (keyingi bosqich: verifikatsiya) ===
ADMIN_TELEGRAM_IDS=123456789,987654321

# === DEFAULT AI (admin / fallback) ===
DEFAULT_AI_PROVIDER=openai
DEFAULT_OPENAI_KEY=
DEFAULT_ANTHROPIC_KEY=
DEFAULT_GEMINI_KEY=
DEFAULT_AI_COST_PER_1K_TOKENS=0.002

# === AGENT ===
AGENT_MAX_ITERATIONS=10
AGENT_COMMAND_TIMEOUT=30
AGENT_MAX_OUTPUT_CHARS=8000

# === MONITORING ===
DEFAULT_MONITORING_INTERVAL_MINUTES=5
METRICS_RETENTION_DAYS=30

# === AI (joriy agent) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
AI_PROVIDER=openai

# === SSH (worker) ===
SSH_KEYS_DIR=./ssh-keys
SSH_PRIVATE_KEY_B64=
SSH_CONNECT_RETRIES=3
SSH_RETRY_BACKOFF_SECONDS=2

# === Telegram bot ===
API_BASE_URL=http://api:8000
HTTP_RETRIES=3
POLL_INTERVAL_SEC=2
POLL_MAX_ROUNDS=180
